<Project>
  <PropertyGroup>
    <AssetsDir>$(MSBuildThisFileDirectory)..\assets\</AssetsDir>
    <AssetExcludes></AssetExcludes>
  </PropertyGroup>

  <ItemGroup Condition="'$(Configuration)' == 'Release'">
    <EmbeddedResource Include="$(IntermediateOutputPath)ContentBundle"
                      LogicalName="ContentBundle"/>
  </ItemGroup>

  <!-- Debug: Copy to folder -->
  <Target Name="BundleContentDebug" AfterTargets="Build" Condition="'$(Configuration)' == 'Debug'">
    <ItemGroup>
      <ContentFiles Include="$(AssetsDir)**\*.*"
                    Exclude="$(AssetExcludes)"/>
    </ItemGroup>

    <Copy SourceFiles="@(ContentFiles)"
          DestinationFiles="@(ContentFiles->'$(OutputPath)Content/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true"/>
  </Target>

  <!-- Debug publish: Copy to publish folder -->
  <Target Name="PublishContentDebug" AfterTargets="Publish" Condition="'$(Configuration)' == 'Debug'">
    <ItemGroup>
      <PublishContentFiles Include="$(AssetsDir)**\*.*"
                           Exclude="$(AssetExcludes)"/>
    </ItemGroup>

    <Copy SourceFiles="@(PublishContentFiles)"
          DestinationFiles="@(PublishContentFiles->'$(PublishDir)Content/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true"/>
  </Target>

  <!-- Release: Bundle and embed into the editor assembly -->
  <Target Name="BundleContent" BeforeTargets="CreateManifestResourceNames" Condition="'$(Configuration)' == 'Release'">
    <ItemGroup>
      <ContentFiles Include="$(AssetsDir)**\*.*"
                    Exclude="$(AssetExcludes)"/>
    </ItemGroup>

    <Copy SourceFiles="@(ContentFiles)"
          DestinationFiles="@(ContentFiles->'$(IntermediateOutputPath)Content\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true"/>

    <Delete Files="$(IntermediateOutputPath)ContentBundle" Condition="Exists('$(IntermediateOutputPath)ContentBundle')"/>
    <ZipDirectory SourceDirectory="$(IntermediateOutputPath)Content"
                  DestinationFile="$(IntermediateOutputPath)ContentBundle"
                  Overwrite="true"/>
  </Target>

  <!-- Clean -->
  <Target Name="CleanBundledContent" AfterTargets="Clean">
    <Delete Files="$(IntermediateOutputPath)ContentBundle"/>
    <RemoveDir Directories="$(IntermediateOutputPath)Content"/>
    <RemoveDir Directories="$(OutputPath)Content"/>
  </Target>
</Project>
